# .env.example — copy to .env and fill in your values
# Never commit .env to git!

# === Required ===
GOOGLE_API_KEY=your-google-api-key-here     # Gemini access for both LangChain and Pydantic AI
TAVILY_API_KEY=your-tavily-api-key-here     # Web search tool

# === LangSmith tracing (optional but recommended) ===
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=deep-dossier
LANGSMITH_TRACING=true

# === Model selection (optional overrides) ===
PLANNER_MODEL_NAME=gemini-2.5-flash
SYNTHESIZE_MODEL_NAME=gemini-2.5-flash
COMPILER_MODEL_NAME=gemini-2.5-flash

# === Memory ===
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=dossier_memory

# === Parallelism + rate limits ===
MAX_PARALLEL_RESEARCHERS=5
RATE_LIMIT_PER_MINUTE=10

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=text          # "text" (dev) or "json" (prod)

# === Server ===
PORT=8000
